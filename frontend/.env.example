# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN= # For source maps upload (CI/CD only)
SENTRY_ORG=your-org
SENTRY_PROJECT=sorotask-frontend
SENTRY_DEBUG=false # Enable debug logs in development

# GitHub OAuth (optional - for GitHub authentication)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (optional - for Google authentication)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email/Password Authentication (optional - for credentials authentication)
# Configure your backend API endpoint for email/password authentication
